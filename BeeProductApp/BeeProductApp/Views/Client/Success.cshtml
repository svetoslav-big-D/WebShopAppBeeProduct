@{
    ViewData["Title"] = "Успешно изтриване";
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">

<div class="container text-center" style="margin-top: 80px; max-width: 550px;">
    <div style="background: white; border: 1px solid #e8d5b0; border-radius: 20px; padding: 50px 30px; box-shadow: 0 4px 15px rgba(65, 36, 2, 0.05);">
        <div style="font-size: 50px; margin-bottom: 20px;">✅</div>
        <h2 style="font-family: 'Playfair Display', serif; color: #412402; margin-bottom: 15px;">Операцията е успешна</h2>
        <p style="font-family: 'DM Sans', sans-serif; color: #633806; margin-bottom: 30px;">
            Потребителят беше премахнат успешно от системата.
        </p>
        <a asp-action="Index" class="btn" style="background: #EF9F27; color: white; border-radius: 8px; padding: 12px 35px; font-weight: 500; text-decoration: none; display: inline-block; transition: 0.3s;">
            Обратно към списъка
        </a>
    </div>
</div>