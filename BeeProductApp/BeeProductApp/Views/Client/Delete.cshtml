@model BeeProductApp.Models.Client.ClientDeleteVM
@{
    ViewData["Title"] = "Изтриване на клиент";
}

<div class="container mt-5" style="max-width: 700px;">
    <h2 style="font-family: 'Playfair Display', serif; color: #412402; margin-bottom: 25px;">Сигурни ли сте, че искате да изтриете този потребител?</h2>

    <div style="background: white; border: 1px solid #e8d5b0; border-radius: 16px; padding: 30px;">
        <div class="row mb-3">
            <div class="col-sm-4" style="color: #854F0B; font-weight: 500; text-transform: uppercase; font-size: 11px;">Потребителско име</div>
            <div class="col-sm-8" style="color: #412402; font-weight: 500;">@Model.UserName</div>
        </div>
        <hr style="border-top: 1px solid #f2e6d0;" />
        <div class="row mb-3">
            <div class="col-sm-4" style="color: #854F0B; font-weight: 500; text-transform: uppercase; font-size: 11px;">Пълно име</div>
            <div class="col-sm-8" style="color: #412402;">@Model.FirstName @Model.LastName</div>
        </div>
        <div class="row mb-3">
            <div class="col-sm-4" style="color: #854F0B; font-weight: 500; text-transform: uppercase; font-size: 11px;">Имейл</div>
            <div class="col-sm-8" style="color: #412402;">@Model.Email</div>
        </div>

        <form asp-action="Delete" class="mt-4 pt-3 d-flex gap-3 border-top" style="border-color: #f2e6d0 !important;">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn" style="background: #dc3545; color: white; border-radius: 8px; padding: 10px 25px; border: none;">Потвърди изтриването</button>
            <a asp-action="Index" class="btn" style="border: 1px solid #BA7517; color: #BA7517; border-radius: 8px; padding: 10px 25px; text-decoration: none;">Отказ</a>
        </form>
    </div>
</div>