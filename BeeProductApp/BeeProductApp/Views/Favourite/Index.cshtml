@using BeeProductApp.Models.Favourite
@model List<FavouriteIndexVM>
@{
    ViewData["Title"] = "My Favourites";
}

<h2 class="mb-4">❤️ My Favourites</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">
        You have no favourite products yet.
        <a asp-controller="Product" asp-action="Index">Browse products</a>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <img src="@item.Picture" class="card-img-top" alt="@item.ProductName"
                         style="height:200px; object-fit:cover;" />
                    <div class="card-body">
                        <h5 class="card-title">@item.ProductName</h5>
                        @if (item.Discount > 0)
                        {
                            <p class="card-text">
                                <span class="text-muted text-decoration-line-through">@item.Price.ToString("F2") лв.</span>
                                <span class="text-danger fw-bold ms-2">@item.DiscountedPrice.ToString("F2") лв.</span>
                                <span class="badge bg-warning text-dark ms-1">-@item.Discount%</span>
                            </p>
                        }
                        else
                        {
                            <p class="card-text fw-bold">@item.Price.ToString("F2") лв.</p>
                        }
                        <p class="card-text text-muted" style="font-size:0.8rem;">Added: @item.AddedOn.ToString("dd MMM yyyy")</p>
                    </div>
                    <div class="card-footer d-flex gap-2">
                        <a asp-controller="Order" asp-action="Create" asp-route-id="@item.ProductId"
                           class="btn btn-warning btn-sm flex-grow-1">🛒 Order</a>

                        <form asp-controller="Cart" asp-action="Add" method="post" class="flex-grow-1">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <input type="hidden" name="quantity" value="1" />
                            <input type="hidden" name="returnUrl" value="/Favourite/Index" />
                            <button type="submit" class="btn btn-outline-warning btn-sm w-100">🧺 Add to Cart</button>
                        </form>

                        <form asp-controller="Favourite" asp-action="Remove" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <input type="hidden" name="returnUrl" value="/Favourite/Index" />
                            <button type="submit" class="btn btn-outline-danger btn-sm"
                                    title="Remove from favourites">
                                ✕
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}

