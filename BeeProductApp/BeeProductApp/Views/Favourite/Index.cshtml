@using BeeProductApp.Models.Favourite
@model List<FavouriteIndexVM>
@{
    ViewData["Title"] = "My Favourites";
}

<h2 class="mb-4">Мойте любими</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">
        You have no favourite products yet.
        <a asp-controller="Product" asp-action="Index" class="alert-link">Browse products</a>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-warning">
                    <img src="@item.Picture" class="card-img-top" alt="@item.ProductName" style="height:200px; object-fit:cover;" />

                    <div class="card-body">
                        <h5 class="card-title text-dark">@item.ProductName</h5>
                        <p class="card-text fw-bold text-success">@item.Price.ToString("F2") лв.</p>
                        <p class="text-muted small">Added: @item.AddedOn.ToString("dd.MM.yyyy")</p>
                    </div>

                    <div class="card-footer bg-white border-top-0 d-flex gap-2">
                        <form asp-controller="Favourite" asp-action="Remove" method="post" class="w-100">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <button type="submit" class="btn btn-sm btn-outline-danger w-100">Remove</button>
                        </form>

                        <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId" class="btn btn-sm btn-warning w-100">View</a>
                    </div>
                </div>
            </div>
        }
    </div>
}