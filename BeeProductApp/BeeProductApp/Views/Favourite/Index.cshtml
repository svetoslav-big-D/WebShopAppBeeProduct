@using BeeProductApp.Models.Favourite
@model List<FavouriteIndexVM>
@{
    ViewData["Title"] = "Любими";
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    * {
        box-sizing: border-box;
    }

    body {
        font-family: 'DM Sans', sans-serif;
        background: #FFF8EE;
        color: #1a1008;
    }

    .page-eyebrow {
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        color: #854F0B;
        margin-bottom: 12px;
    }

    .page-title {
        font-family: 'Playfair Display', serif;
        font-size: 38px;
        color: #412402;
        margin-bottom: 8px;
        line-height: 1.2;
    }

        .page-title em {
            font-style: italic;
            color: #BA7517;
        }

    .page-subtitle {
        font-size: 14px;
        color: #854F0B;
        margin-bottom: 40px;
    }

    /* ── EMPTY STATE ── */
    .empty-state {
        background: white;
        border: 1px solid #e8d5b0;
        border-radius: 16px;
        padding: 72px 40px;
        text-align: center;
        margin-bottom: 60px;
    }

    .empty-icon {
        font-size: 52px;
        margin-bottom: 20px;
    }

    .empty-title {
        font-family: 'Playfair Display', serif;
        font-size: 22px;
        color: #412402;
        margin-bottom: 10px;
    }

    .empty-sub {
        font-size: 14px;
        color: #854F0B;
        margin-bottom: 28px;
    }

    .empty-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #412402;
        color: #FAC775;
        border: none;
        padding: 13px 28px;
        border-radius: 4px;
        font-size: 14px;
        font-weight: 500;
        text-decoration: none;
        transition: background 0.2s;
    }

        .empty-btn:hover {
            background: #633806;
            color: #FAC775;
            text-decoration: none;
        }

    /* ── FAVOURITES GRID ── */
    .fav-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        margin-bottom: 60px;
    }

    .fav-card {
        background: white;
        border: 1px solid #e8d5b0;
        border-radius: 14px;
        width: 220px;
        overflow: hidden;
        transition: border-color 0.2s, transform 0.2s;
    }

        .fav-card:hover {
            border-color: #EF9F27;
            transform: translateY(-2px);
        }

    .fav-img-wrap {
        height: 150px;
        overflow: hidden;
        background: #FAEEDA;
    }

        .fav-img-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

    .fav-body {
        padding: 14px;
    }

    .fav-name {
        font-size: 14px;
        font-weight: 500;
        color: #412402;
        margin-bottom: 4px;
    }

    .fav-date {
        font-size: 11px;
        color: #854F0B;
        margin-bottom: 10px;
    }

    .fav-price {
        font-family: 'Playfair Display', serif;
        font-size: 17px;
        color: #BA7517;
        margin-bottom: 14px;
    }

    .fav-actions {
        display: flex;
        gap: 8px;
    }

    .btn-view {
        flex: 1;
        background: #412402;
        color: #FAC775;
        border: none;
        padding: 8px 0;
        border-radius: 4px;
        font-size: 12px;
        font-weight: 500;
        text-align: center;
        text-decoration: none;
        transition: background 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .btn-view:hover {
            background: #633806;
            color: #FAC775;
            text-decoration: none;
        }

    .btn-remove {
        flex: 1;
        background: white;
        color: #854F0B;
        border: 1px solid #e8d5b0;
        padding: 8px 0;
        border-radius: 4px;
        font-size: 12px;
        font-weight: 500;
        cursor: pointer;
        transition: border-color 0.2s, background 0.2s;
        width: 100%;
    }

        .btn-remove:hover {
            border-color: #BA7517;
            background: #FAEEDA;
        }
</style>

<div class="page-eyebrow">Вашата колекция</div>
<h1 class="page-title">Моите <em>любими</em></h1>
<p class="page-subtitle">Продукти, които сте запазили за по-късно</p>

@if (!Model.Any())
{
    <div class="empty-state">
        <div class="empty-icon">🍯</div>
        <div class="empty-title">Все още нямате любими продукти</div>
        <p class="empty-sub">Разгледайте нашите продукти и добавете любимите си.</p>
        <a asp-controller="Product" asp-action="Index" class="empty-btn">Разгледай продуктите →</a>
    </div>
}
else
{
    <div class="fav-grid">
        @foreach (var item in Model)
        {
            <div class="fav-card">
                <div class="fav-img-wrap">
                    <img src="@item.Picture" alt="@item.ProductName" />
                </div>
                <div class="fav-body">
                    <div class="fav-name">@item.ProductName</div>
                    <div class="fav-date">Добавен: @item.AddedOn.ToString("dd.MM.yyyy")</div>
                    <div class="fav-price">@item.Price.ToString("F2") лв.</div>
                    <div class="fav-actions">
                        <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId" class="btn-view">Виж</a>
                        <form asp-controller="Favourite" asp-action="Remove" method="post" style="flex:1; margin:0;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <button type="submit" class="btn-remove">Премахни</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
