@{
    ViewData["Title"] = "Order Placed!";
}

<div class="text-center mt-5">
    <h2>✅ Your order was placed successfully!</h2>
    <p class="text-muted">Thank you for shopping at BeeProductApp.</p>
    <a asp-controller="Order" asp-action="MyOrders" class="btn btn-warning mt-3">View My Orders</a>
    <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary mt-3 ms-2">Continue Shopping</a>
</div>
