@{
    ViewData["Title"] = "Недостатъчна наличност";
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    * {
        box-sizing: border-box;
    }

    body {
        font-family: 'DM Sans', sans-serif;
        background: #FFF8EE;
        color: #1a1008;
    }

    .denied-wrap {
        max-width: 520px;
        margin: 60px auto;
        background: white;
        border: 1px solid #f5c6c6;
        border-radius: 16px;
        padding: 60px 48px;
        text-align: center;
    }

    .denied-icon {
        font-size: 56px;
        margin-bottom: 20px;
    }

    .denied-title {
        font-family: 'Playfair Display', serif;
        font-size: 28px;
        color: #412402;
        margin-bottom: 12px;
        line-height: 1.2;
    }

        .denied-title em {
            font-style: italic;
            color: #7a1f1f;
        }

    .denied-sub {
        font-size: 14px;
        color: #854F0B;
        line-height: 1.75;
        margin-bottom: 36px;
    }

    .denied-box {
        background: #fde8e8;
        border: 1px solid #f5c6c6;
        border-radius: 10px;
        padding: 14px 18px;
        font-size: 13px;
        color: #7a1f1f;
        margin-bottom: 32px;
        display: flex;
        align-items: center;
        gap: 10px;
        text-align: left;
    }

    .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #412402;
        color: #FAC775;
        border: none;
        padding: 13px 28px;
        border-radius: 4px;
        font-size: 14px;
        font-weight: 500;
        text-decoration: none;
        transition: background 0.2s;
    }

        .btn-primary:hover {
            background: #633806;
            color: #FAC775;
            text-decoration: none;
        }
</style>

<div class="denied-wrap">
    <div class="denied-icon">⚠️</div>
    <h1 class="denied-title">Недостатъчна <em>наличност</em></h1>
    <p class="denied-sub">За съжаление, заявеното количество надвишава наличните бройки на този продукт.</p>
    <div class="denied-box">
        Моля, намалете количеството или изберете друг продукт.
    </div>
    <a asp-controller="Product" asp-action="Index" class="btn-primary">← Обратно към продуктите</a>
</div>
@{
	ViewData["Title"] = "Denied";
}

<h1>Insufficient availability</h1>

<div>
	<a asp-controller="Product" asp-action="Index">Back to list of products</a>
</div>