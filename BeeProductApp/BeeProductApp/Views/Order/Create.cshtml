@model BeeProductApp.Models.Order.OrderCreateVM
@{
    ViewData["Title"] = "Поръчка";
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    * {
        box-sizing: border-box;
    }

    body {
        font-family: 'DM Sans', sans-serif;
        background: #FFF8EE;
        color: #1a1008;
    }

    .back-link {
        font-size: 13px;
        color: #BA7517;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 28px;
    }

        .back-link:hover {
            color: #854F0B;
            text-decoration: none;
        }

    .page-eyebrow {
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        color: #854F0B;
        margin-bottom: 12px;
    }

    .page-title {
        font-family: 'Playfair Display', serif;
        font-size: 34px;
        color: #412402;
        margin-bottom: 32px;
        line-height: 1.2;
    }

        .page-title em {
            font-style: italic;
            color: #BA7517;
        }

    .order-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0;
        border: 1px solid #e8d5b0;
        border-radius: 16px;
        overflow: hidden;
        max-width: 760px;
        margin-bottom: 40px;
        background: white;
    }

    .order-img-side {
        overflow: hidden;
        background: #FAEEDA;
        min-height: 320px;
    }

        .order-img-side img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

    .order-form-side {
        padding: 40px 36px;
    }

    .prod-name-display {
        font-family: 'Playfair Display', serif;
        font-size: 22px;
        color: #412402;
        margin-bottom: 6px;
    }

    .prod-price-display {
        font-family: 'Playfair Display', serif;
        font-size: 20px;
        color: #BA7517;
        margin-bottom: 4px;
    }

    .prod-discount-display {
        font-size: 12px;
        font-weight: 500;
        background: #FAEEDA;
        color: #854F0B;
        padding: 3px 10px;
        border-radius: 20px;
        display: inline-block;
        margin-bottom: 24px;
    }

    .form-divider {
        border: none;
        border-top: 1px solid #e8d5b0;
        margin: 20px 0;
    }

    .field-group {
        margin-bottom: 20px;
    }

    .field-label {
        display: block;
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #854F0B;
        margin-bottom: 6px;
    }

    .field-input {
        width: 100%;
        padding: 10px 14px;
        border: 1px solid #e8d5b0;
        border-radius: 6px;
        font-family: 'DM Sans', sans-serif;
        font-size: 14px;
        color: #412402;
        background: #FFFDF8;
        transition: border-color 0.2s;
        outline: none;
    }

        .field-input:focus {
            border-color: #EF9F27;
        }

        .field-input[readonly] {
            background: #f7f0e6;
            color: #854F0B;
            cursor: default;
        }

    .field-error {
        color: #7a1f1f;
        font-size: 12px;
        margin-top: 4px;
        display: block;
    }

    .total-box {
        background: #FAEEDA;
        border: 1px solid #e8d5b0;
        border-radius: 10px;
        padding: 16px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }

    .total-label {
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #854F0B;
    }

    .total-value {
        font-family: 'Playfair Display', serif;
        font-size: 22px;
        color: #BA7517;
    }

    .form-actions {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .btn-submit {
        background: #412402;
        color: #FAC775;
        border: none;
        padding: 13px 28px;
        border-radius: 4px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.2s;
        flex: 1;
    }

        .btn-submit:hover {
            background: #633806;
        }

    .btn-cancel {
        background: white;
        color: #412402;
        border: 1px solid #e8d5b0;
        padding: 13px 20px;
        border-radius: 4px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        transition: border-color 0.2s, background 0.2s;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

        .btn-cancel:hover {
            border-color: #BA7517;
            background: #FAEEDA;
            text-decoration: none;
            color: #412402;
        }

    .validation-summary {
        background: #fde8e8;
        border: 1px solid #f5c6c6;
        border-radius: 8px;
        padding: 12px 16px;
        margin-bottom: 20px;
        font-size: 13px;
        color: #7a1f1f;
    }
</style>

<a asp-action="Index" asp-controller="Product" class="back-link">← Обратно към продуктите</a>

<div class="page-eyebrow">Нова поръчка</div>
<h1 class="page-title">Завърши <em>поръчката</em></h1>

<div class="order-layout">
    <div class="order-img-side">
        <img src="@Html.DisplayFor(model => model.Picture)" alt="@Model.ProductName" />
    </div>
    <div class="order-form-side">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <input type="hidden" asp-for="ProductId" />
            <input type="hidden" asp-for="Picture" />

            <div class="prod-name-display">@Html.DisplayFor(model => model.ProductName)</div>
            <input type="hidden" asp-for="ProductName" />

            <div class="prod-price-display">@Html.DisplayFor(model => model.Price) лв.</div>
            <input type="hidden" asp-for="Price" />

            @if (Model.Discount > 0)
            {
                <div class="prod-discount-display">Отстъпка: @Html.DisplayFor(model => model.Discount)%</div>
            }
            <input type="hidden" asp-for="Discount" />

            <hr class="form-divider" />

            <div class="field-group">
                <label asp-for="Quantity" class="field-label">Количество (макс. @Model.QuantityInStock)</label>
                <input asp-for="Quantity" class="field-input" oninput="calcSum()" placeholder="Въведи количество" />
                <span asp-validation-for="Quantity" class="field-error"></span>
            </div>

            <div class="total-box">
                <span class="total-label">Обща сума</span>
                <span class="total-value"><span id="total-display">0.00</span> лв.</span>
            </div>
            <input type="hidden" asp-for="TotalPrice" id="TotalPrice" />

            <div class="form-actions">
                <button type="submit" class="btn-submit">Поръчай сега</button>
                <a asp-action="Index" asp-controller="Product" class="btn-cancel">Откажи</a>
            </div>
        </form>
    </div>
</div>

<script>
    var maxQty = @Model.QuantityInStock;
    var qtyInput = document.getElementById('Quantity');
    qtyInput.max = maxQty;
    qtyInput.min = 1;

    function calcSum() {
        let q = document.getElementsByName('Quantity')[0].value;
        let p = @Model.Price;
        let d = @Model.Discount;
        let sum = Number(q) * (p - p * d / 100);
        let rounded = sum.toFixed(2);
        document.getElementById('TotalPrice').value = rounded;
        document.getElementById('total-display').textContent = rounded;
    }

    calcSum();
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
