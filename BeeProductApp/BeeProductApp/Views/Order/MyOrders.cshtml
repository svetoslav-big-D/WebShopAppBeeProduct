@model IEnumerable<BeeProductApp.Models.Order.OrderIndexVM>
@{
    ViewData["Title"] = "Моите поръчки";
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    * {
        box-sizing: border-box;
    }

    body {
        font-family: 'DM Sans', sans-serif;
        background: #FFF8EE;
        color: #1a1008;
    }

    .page-eyebrow {
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        color: #854F0B;
        margin-bottom: 12px;
    }

    .page-title {
        font-family: 'Playfair Display', serif;
        font-size: 38px;
        color: #412402;
        margin-bottom: 8px;
        line-height: 1.2;
    }

        .page-title em {
            font-style: italic;
            color: #BA7517;
        }

    .page-subtitle {
        font-size: 14px;
        color: #854F0B;
        margin-bottom: 32px;
    }

    .orders-grid {
        display: flex;
        flex-direction: column;
        gap: 14px;
        margin-bottom: 60px;
    }

    .order-card {
        background: white;
        border: 1px solid #e8d5b0;
        border-radius: 14px;
        overflow: hidden;
        display: grid;
        grid-template-columns: 90px 1fr;
        transition: border-color 0.2s;
    }

        .order-card:hover {
            border-color: #EF9F27;
        }

    .order-card-img {
        overflow: hidden;
        background: #FAEEDA;
    }

        .order-card-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            min-height: 90px;
        }

    .order-card-body {
        padding: 16px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
    }

    .order-info {
        flex: 1;
        min-width: 140px;
    }

    .order-product-name {
        font-size: 15px;
        font-weight: 500;
        color: #412402;
        margin-bottom: 4px;
    }

    .order-date {
        font-size: 12px;
        color: #854F0B;
    }

    .order-qty {
        text-align: center;
        min-width: 60px;
    }

    .qty-num {
        font-size: 18px;
        font-weight: 500;
        color: #412402;
    }

    .qty-label {
        font-size: 11px;
        color: #854F0B;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .order-price-group {
        text-align: right;
        min-width: 100px;
    }

    .order-price {
        font-size: 12px;
        color: #854F0B;
        margin-bottom: 2px;
    }

    .order-discount {
        display: inline-block;
        font-size: 11px;
        font-weight: 500;
        background: #FAEEDA;
        color: #854F0B;
        padding: 2px 8px;
        border-radius: 20px;
        margin-bottom: 4px;
    }

    .order-total {
        font-family: 'Playfair Display', serif;
        font-size: 20px;
        color: #BA7517;
    }

    .empty-state {
        background: white;
        border: 1px solid #e8d5b0;
        border-radius: 16px;
        padding: 72px 40px;
        text-align: center;
        margin-bottom: 60px;
    }

    .empty-icon {
        font-size: 52px;
        margin-bottom: 20px;
    }

    .empty-title {
        font-family: 'Playfair Display', serif;
        font-size: 22px;
        color: #412402;
        margin-bottom: 10px;
    }

    .empty-sub {
        font-size: 14px;
        color: #854F0B;
        margin-bottom: 28px;
    }

    .btn-browse {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #412402;
        color: #FAC775;
        border: none;
        padding: 13px 28px;
        border-radius: 4px;
        font-size: 14px;
        font-weight: 500;
        text-decoration: none;
        transition: background 0.2s;
    }

        .btn-browse:hover {
            background: #633806;
            color: #FAC775;
            text-decoration: none;
        }
</style>

<div class="page-eyebrow">Вашият акаунт</div>
<h1 class="page-title">Моите <em>поръчки</em></h1>
<p class="page-subtitle">История на всичките ви поръчки</p>

@if (!Model.Any())
{
    <div class="empty-state">
        <div class="empty-icon">📦</div>
        <div class="empty-title">Все още нямате поръчки</div>
        <p class="empty-sub">Разгледайте нашите продукти и направете първата си поръчка.</p>
        <a asp-controller="Product" asp-action="Index" class="btn-browse">Разгледай продуктите →</a>
    </div>
}
else
{
    <div class="orders-grid">
        @foreach (var item in Model)
        {
            <div class="order-card">
                <div class="order-card-img">
                    <img src="@Html.DisplayFor(modelItem => item.Picture)" alt="@item.Product" />
                </div>
                <div class="order-card-body">
                    <div class="order-info">
                        <div class="order-product-name">@Html.DisplayFor(modelItem => item.Product)</div>
                        <div class="order-date">@Html.DisplayFor(modelItem => item.OrderDate)</div>
                    </div>
                    <div class="order-qty">
                        <div class="qty-num">@Html.DisplayFor(modelItem => item.Quantity)</div>
                        <div class="qty-label">бр.</div>
                    </div>
                    <div class="order-price-group">
                        <div class="order-price">@Html.DisplayFor(modelItem => item.Price) лв. / бр.</div>
                        @if (item.Discount > 0)
                        {
                            <div class="order-discount">-@Html.DisplayFor(modelItem => item.Discount)%</div>
                        }
                        <div class="order-total">@Html.DisplayFor(modelItem => item.TotalPrice) лв.</div>
                    </div>
                </div>
            </div>
        }
    </div>
}
