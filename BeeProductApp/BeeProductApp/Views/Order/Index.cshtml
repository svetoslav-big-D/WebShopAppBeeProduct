@model IEnumerable<BeeProductApp.Models.Order.OrderIndexVM>
@{
    ViewData["Title"] = "Всички поръчки";
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    * {
        box-sizing: border-box;
    }

    body {
        font-family: 'DM Sans', sans-serif;
        background: #FFF8EE;
        color: #1a1008;
    }

    .page-eyebrow {
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        color: #854F0B;
        margin-bottom: 12px;
    }

    .page-title {
        font-family: 'Playfair Display', serif;
        font-size: 38px;
        color: #412402;
        margin-bottom: 8px;
        line-height: 1.2;
    }

        .page-title em {
            font-style: italic;
            color: #BA7517;
        }

    .page-subtitle {
        font-size: 14px;
        color: #854F0B;
        margin-bottom: 32px;
    }

    .orders-table-wrap {
        background: white;
        border: 1px solid #e8d5b0;
        border-radius: 16px;
        overflow: hidden;
        margin-bottom: 60px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    thead tr {
        background: #FAEEDA;
        border-bottom: 1px solid #e8d5b0;
    }

    th {
        padding: 14px 16px;
        text-align: left;
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #854F0B;
    }

    tbody tr {
        border-bottom: 1px solid #f0e4cc;
        transition: background 0.15s;
    }

        tbody tr:last-child {
            border-bottom: none;
        }

        tbody tr:hover {
            background: #FFFDF8;
        }

    td {
        padding: 14px 16px;
        font-size: 13px;
        color: #412402;
        vertical-align: middle;
    }

    .order-img {
        width: 56px;
        height: 56px;
        object-fit: cover;
        border-radius: 8px;
        border: 1px solid #e8d5b0;
        display: block;
    }

    .order-date {
        font-size: 12px;
        color: #854F0B;
    }

    .order-user {
        font-weight: 500;
        color: #412402;
    }

    .order-product {
        font-weight: 500;
        color: #412402;
    }

    .price-cell {
        font-family: 'Playfair Display', serif;
        font-size: 15px;
        color: #BA7517;
    }

    .total-cell {
        font-family: 'Playfair Display', serif;
        font-size: 15px;
        color: #412402;
        font-weight: 700;
    }

    .discount-pill {
        font-size: 11px;
        font-weight: 500;
        background: #FAEEDA;
        color: #854F0B;
        padding: 3px 8px;
        border-radius: 20px;
    }

    .empty-state {
        padding: 60px;
        text-align: center;
    }

    .empty-icon {
        font-size: 48px;
        margin-bottom: 16px;
    }

    .empty-title {
        font-family: 'Playfair Display', serif;
        font-size: 20px;
        color: #412402;
        margin-bottom: 8px;
    }

    .empty-sub {
        font-size: 13px;
        color: #854F0B;
    }
</style>

<div class="page-eyebrow">Администрация</div>
<h1 class="page-title">Всички <em>поръчки</em></h1>
<p class="page-subtitle">Преглед на всички поръчки в системата</p>

<div class="orders-table-wrap">
    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">📦</div>
            <div class="empty-title">Все още няма поръчки</div>
            <p class="empty-sub">Поръчките ще се появят тук след като клиентите направят покупка.</p>
        </div>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Снимка</th>
                    <th>@Html.DisplayNameFor(model => model.OrderDate)</th>
                    <th>@Html.DisplayNameFor(model => model.User)</th>
                    <th>@Html.DisplayNameFor(model => model.Product)</th>
                    <th>@Html.DisplayNameFor(model => model.Quantity)</th>
                    <th>@Html.DisplayNameFor(model => model.Price)</th>
                    <th>@Html.DisplayNameFor(model => model.Discount)</th>
                    <th>@Html.DisplayNameFor(model => model.TotalPrice)</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><img src="@Html.DisplayFor(modelItem => item.Picture)" alt="@item.Product" class="order-img" /></td>
                        <td><span class="order-date">@Html.DisplayFor(modelItem => item.OrderDate)</span></td>
                        <td><span class="order-user">@Html.DisplayFor(modelItem => item.User)</span></td>
                        <td><span class="order-product">@Html.DisplayFor(modelItem => item.Product)</span></td>
                        <td>@Html.DisplayFor(modelItem => item.Quantity) бр.</td>
                        <td><span class="price-cell">@Html.DisplayFor(modelItem => item.Price) лв.</span></td>
                        <td>
                            @if (item.Discount > 0)
                            {
                                <span class="discount-pill">-@Html.DisplayFor(modelItem => item.Discount)%</span>
                            }
                            else
                            {
                                <span style="color:#854F0B; font-size:12px;">—</span>
                            }
                        </td>
                        <td><span class="total-cell">@Html.DisplayFor(modelItem => item.TotalPrice) лв.</span></td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
