@{
    ViewData["Title"] = "За нас";
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    * {
        box-sizing: border-box;
    }

    body {
        font-family: 'DM Sans', sans-serif;
        background: #FFF8EE;
        color: #1a1008;
    }

    .page-eyebrow {
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        color: #854F0B;
        margin-bottom: 12px;
    }

    .page-title {
        font-family: 'Playfair Display', serif;
        font-size: 38px;
        color: #412402;
        margin-bottom: 16px;
        line-height: 1.2;
    }

        .page-title em {
            font-style: italic;
            color: #BA7517;
        }

    .page-subtitle {
        font-size: 15px;
        color: #633806;
        line-height: 1.75;
        max-width: 560px;
        margin-bottom: 48px;
    }

    /* ── STORY SECTION ── */
    .story {
        display: grid;
        grid-template-columns: 1fr 1fr;
        border: 1px solid #e8d5b0;
        border-radius: 16px;
        overflow: hidden;
        margin-bottom: 40px;
    }

    .story-img-side {
        overflow: hidden;
        min-height: 300px;
    }

        .story-img-side img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

    .story-text-side {
        padding: 48px 44px;
        background: #FAEEDA;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .story-eyebrow {
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        color: #854F0B;
        margin-bottom: 12px;
    }

    .story-title {
        font-family: 'Playfair Display', serif;
        font-size: 24px;
        color: #412402;
        margin-bottom: 14px;
        line-height: 1.3;
    }

    .story-body {
        font-size: 14px;
        color: #633806;
        line-height: 1.85;
    }

    /* ── TEAM ── */
    .section-title {
        font-family: 'Playfair Display', serif;
        font-size: 26px;
        color: #412402;
        margin-bottom: 20px;
    }

    .team-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-bottom: 40px;
    }

    .team-card {
        background: white;
        border: 1px solid #e8d5b0;
        border-radius: 14px;
        padding: 32px 28px;
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .team-avatar {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: #FAEEDA;
        border: 2px solid #EF9F27;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Playfair Display', serif;
        font-size: 22px;
        color: #BA7517;
        flex-shrink: 0;
    }

    .team-name {
        font-family: 'Playfair Display', serif;
        font-size: 18px;
        color: #412402;
        margin-bottom: 4px;
    }

    .team-role {
        font-size: 12px;
        color: #854F0B;
        font-weight: 500;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    /* ── CONTACT ── */
    .contact-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        margin-bottom: 60px;
    }

    .contact-card {
        background: white;
        border: 1px solid #e8d5b0;
        border-radius: 14px;
        padding: 28px 24px;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .contact-icon {
        font-size: 24px;
    }

    .contact-label {
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #854F0B;
    }

    .contact-value {
        font-size: 14px;
        color: #412402;
        font-weight: 500;
        word-break: break-word;
    }

        .contact-value a {
            color: #BA7517;
            text-decoration: none;
        }

            .contact-value a:hover {
                text-decoration: underline;
            }
</style>

<div class="page-eyebrow">Запознайте се с нас</div>
<h1 class="page-title">Хората зад <em>меда</em></h1>
<p class="page-subtitle">
    Ние сме двама приятели с обща страст към природата, пчелите и истинските, чисти продукти.
    Всичко започна в село Кралевдол — и продължава с любов всеки ден.
</p>

<!-- STORY -->
<div class="story">
    <div class="story-img-side">
        <img src="https://images.unsplash.com/photo-1558642452-9d2a7deb7f62?w=700&q=80" alt="Пчелин">
    </div>
    <div class="story-text-side">
        <div class="story-eyebrow">Нашата история</div>
        <h2 class="story-title">Семеен пчелин с над 20 години традиция</h2>
        <p class="story-body">
            Пчелинът ни се намира в живописното село Кралевдол, в сърцето на природата.
            С над 50 кошера и 20+ години опит, ние предлагаме 100% натурални пчелни продукти —
            без добавки, без компромиси. Всяка капка мед носи вкуса на нашия труд и любов.
        </p>
    </div>
</div>

