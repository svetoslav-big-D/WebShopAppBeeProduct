@model WebShopApp.Models.Product.ProductEditVM
@{
    ViewData["Title"] = "Редактирай";
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    * {
        box-sizing: border-box;
    }

    body {
        font-family: 'DM Sans', sans-serif;
        background: #FFF8EE;
        color: #1a1008;
    }

    .back-link {
        font-size: 13px;
        color: #BA7517;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 28px;
    }

        .back-link:hover {
            color: #854F0B;
            text-decoration: none;
        }

    .page-eyebrow {
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        color: #854F0B;
        margin-bottom: 12px;
    }

    .page-title {
        font-family: 'Playfair Display', serif;
        font-size: 34px;
        color: #412402;
        margin-bottom: 32px;
        line-height: 1.2;
    }

        .page-title em {
            font-style: italic;
            color: #BA7517;
        }

    .form-card {
        background: white;
        border: 1px solid #e8d5b0;
        border-radius: 16px;
        padding: 40px 36px;
        max-width: 580px;
        margin-bottom: 40px;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0 20px;
    }

    .field-full {
        grid-column: 1 / -1;
    }

    .field-group {
        margin-bottom: 20px;
    }

    .field-label {
        display: block;
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #854F0B;
        margin-bottom: 6px;
    }

    .field-input, .field-select {
        width: 100%;
        padding: 10px 14px;
        border: 1px solid #e8d5b0;
        border-radius: 6px;
        font-family: 'DM Sans', sans-serif;
        font-size: 14px;
        color: #412402;
        background: #FFFDF8;
        transition: border-color 0.2s;
        outline: none;
        appearance: none;
    }

        .field-input:focus, .field-select:focus {
            border-color: #EF9F27;
        }

    .field-error {
        color: #7a1f1f;
        font-size: 12px;
        margin-top: 4px;
        display: block;
    }

    .form-divider {
        border: none;
        border-top: 1px solid #e8d5b0;
        margin: 24px 0;
    }

    .form-actions {
        display: flex;
        gap: 12px;
        align-items: center;
        margin-top: 8px;
    }

    .btn-submit {
        background: #412402;
        color: #FAC775;
        border: none;
        padding: 13px 28px;
        border-radius: 4px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.2s;
    }

        .btn-submit:hover {
            background: #633806;
        }

    .btn-cancel {
        font-size: 13px;
        color: #BA7517;
        text-decoration: none;
    }

        .btn-cancel:hover {
            color: #854F0B;
            text-decoration: underline;
        }

    .validation-summary {
        background: #fde8e8;
        border: 1px solid #f5c6c6;
        border-radius: 8px;
        padding: 12px 16px;
        margin-bottom: 20px;
        font-size: 13px;
        color: #7a1f1f;
    }
</style>

<a asp-action="Index" class="back-link">← Обратно към продуктите</a>

<div class="page-eyebrow">Администрация</div>
<h1 class="page-title">Редактирай <em>продукт</em></h1>

<div class="form-card">
    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
        <input type="hidden" asp-for="Id" />

        <div class="form-grid">
            <div class="field-group field-full">
                <label asp-for="ProductName" class="field-label"></label>
                <input asp-for="ProductName" class="field-input" />
                <span asp-validation-for="ProductName" class="field-error"></span>
            </div>

            <div class="field-group">
                <label asp-for="BrandId" class="field-label"></label>
                <select asp-for="BrandId" class="field-select">
                    @foreach (var brand in Model.Brands)
                    {
                        <option value=" @brand.Id">@brand.Name</option>
                    }
                </select>
                <span asp-validation-for="BrandId" class="field-error"></span>
            </div>

            <div class="field-group">
                <label asp-for="CategoryId" class="field-label"></label>
                <select asp-for="CategoryId" class="field-select">
                    @foreach (var category in Model.Categories)
                    {
                        <option value="@category.Id">@category.Name</option>
                    }
                </select>
                <span asp-validation-for="CategoryId" class="field-error"></span>
            </div>

            <div class="field-group field-full">
                <label asp-for="Picture" class="field-label"></label>
                <input asp-for="Picture" class="field-input" />
                <span asp-validation-for="Picture" class="field-error"></span>
            </div>

            <div class="field-group field-full">
                <label asp-for="Description" class="field-label"></label>
                <input asp-for="Description" class="field-input" />
                <span asp-validation-for="Description" class="field-error"></span>
            </div>

            <div class="field-group">
                <label asp-for="Quantity" class="field-label"></label>
                <input asp-for="Quantity" class="field-input" />
                <span asp-validation-for="Quantity" class="field-error"></span>
            </div>

            <div class="field-group">
                <label asp-for="Price" class="field-label"></label>
                <input asp-for="Price" class="field-input" />
                <span asp-validation-for="Price" class="field-error"></span>
            </div>

            <div class="field-group">
                <label asp-for="Discount" class="field-label"></label>
                <input asp-for="Discount" class="field-input" />
                <span asp-validation-for="Discount" class="field-error"></span>
            </div>
        </div>

        <hr class="form-divider" />

        <div class="form-actions">
            <button type="submit" class="btn-submit">Запази промените</button>
            <a asp-action="Index" class="btn-cancel">Откажи</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
