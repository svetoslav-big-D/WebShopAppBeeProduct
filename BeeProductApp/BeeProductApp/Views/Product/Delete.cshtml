@model BeeProductApp.Models.Product.ProductDeleteVM
@{
    ViewData["Title"] = "Изтриване";
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    * {
        box-sizing: border-box;
    }

    body {
        font-family: 'DM Sans', sans-serif;
        background: #FFF8EE;
        color: #1a1008;
    }

    .back-link {
        font-size: 13px;
        color: #BA7517;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 28px;
    }

        .back-link:hover {
            color: #854F0B;
            text-decoration: none;
        }

    .page-eyebrow {
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        color: #854F0B;
        margin-bottom: 12px;
    }

    .page-title {
        font-family: 'Playfair Display', serif;
        font-size: 34px;
        color: #412402;
        margin-bottom: 8px;
        line-height: 1.2;
    }

    .page-subtitle {
        font-size: 14px;
        color: #7a1f1f;
        margin-bottom: 32px;
    }

    .delete-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0;
        border: 1px solid #f5c6c6;
        border-radius: 16px;
        overflow: hidden;
        max-width: 740px;
        margin-bottom: 40px;
        background: white;
    }

    .delete-img-side {
        min-height: 280px;
        overflow: hidden;
        background: #FAEEDA;
    }

        .delete-img-side img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

    .delete-info-side {
        padding: 40px 36px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .delete-prod-name {
        font-family: 'Playfair Display', serif;
        font-size: 22px;
        color: #412402;
        margin-bottom: 20px;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 0;
        border-bottom: 1px solid #f0e4cc;
    }

        .info-row:last-of-type {
            border-bottom: none;
        }

    .info-key {
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #854F0B;
    }

    .info-val {
        font-size: 14px;
        color: #412402;
        font-weight: 500;
    }

    .warning-box {
        background: #fde8e8;
        border: 1px solid #f5c6c6;
        border-radius: 10px;
        padding: 14px 18px;
        font-size: 13px;
        color: #7a1f1f;
        margin: 24px 0 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .delete-actions {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .btn-delete {
        background: #7a1f1f;
        color: #fde8e8;
        border: none;
        padding: 13px 28px;
        border-radius: 4px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.2s;
    }

        .btn-delete:hover {
            background: #5c1515;
        }

    .btn-cancel {
        font-size: 13px;
        color: #BA7517;
        text-decoration: none;
    }

        .btn-cancel:hover {
            color: #854F0B;
            text-decoration: underline;
        }
</style>

<a asp-action="Index" class="back-link">← Обратно към продуктите</a>

<div class="page-eyebrow">Администрация</div>
<h1 class="page-title">Изтриване на продукт</h1>
<p class="page-subtitle">Моля, потвърдете, че искате да изтриете този продукт.</p>

<div class="delete-layout">
    <div class="delete-img-side">
        <img src="@Html.DisplayFor(model => model.Picture)" alt="@Model.ProductName" />
    </div>
    <div class="delete-info-side">
        <div class="delete-prod-name">@Html.DisplayFor(model => model.ProductName)</div>

        <div class="info-row">
            <span class="info-key">Марка</span>
            <span class="info-val">@Html.DisplayFor(model => model.BrandName)</span>
        </div>
        <div class="info-row">
            <span class="info-key">Категория</span>
            <span class="info-val">@Html.DisplayFor(model => model.CategoryName)</span>
        </div>
        <div class="info-row">
            <span class="info-key">Цена</span>
            <span class="info-val">@Html.DisplayFor(model => model.Price) лв.</span>
        </div>
        <div class="info-row">
            <span class="info-key">Наличност</span>
            <span class="info-val">@Html.DisplayFor(model => model.Quantity) бр.</span>
        </div>
        <div class="info-row">
            <span class="info-key">Отстъпка</span>
            <span class="info-val">@Html.DisplayFor(model => model.Discount)%</span>
        </div>

        <div class="warning-box">
            ⚠️ Това действие е необратимо. Продуктът ще бъде изтрит завинаги.
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="delete-actions">
                <button type="submit" class="btn-delete">Изтрий продукта</button>
                <a asp-action="Index" class="btn-cancel">Откажи</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
